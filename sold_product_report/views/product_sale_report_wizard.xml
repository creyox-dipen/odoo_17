<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_sale_report" model="ir.ui.view">
        <field name="name">product.sale.report.form.view</field>
        <field name="model">product.sale.report</field>
        <field name="arch" type="xml">
            <form string="Product Sales Report">
                <group>
                    <group>
                        <field name="start_date"/>
                        <field name="report_type" widget="radio"/>
                    </group>
                    <group>
                        <field name="end_date"/>
                        <field name="categ_id" options="{'no_create': True, 'no_create_edit':True}" widget="many2many_tags"/>
<!--                        <field name="warehouse_id" options="{'no_create': True, 'no_create_edit':True}" widget="many2many_tags"/>-->
                    </group>
                </group>
                <footer>
                    <button name="generate_product_sale_report" string="Print" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>

